{
    "manifest_version": 3,
    "name": "XCHECK Extension",
    "version": "1.0",
    "action": {
        "default_popup": "popup.html",
        "default_title": "XCHECK Extension"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*",
        "https://factchecktools.googleapis.com/*"
    ],
    "background": {
        "service_worker": "dist/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost:8000/*",
                "file:///*"
            ],
            "js": [
                "dist/content-script.js"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "shield.png"
            ],
            "matches": [
                "http://localhost:8000/*"
            ]
        }
    ]
}
